{
  "$schema": "https://json.schemastore.org/claude-code-settings",
  "description": "delabie-tech: client-side guardrails for any Claude Code agent. Server-side branch-protection rules are the authoritative gate (see .github/branch-protection.json).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "command": "scripts/hooks/pre-bash.sh",
        "description": "Block main pushes, force-pushes, merges, and protection changes before they happen"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "command": "scripts/hooks/post-write.sh",
        "description": "Warn if a protected file was just modified without approval"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout -b feature/*:*)",
      "Bash(git checkout -b fix/*:*)",
      "Bash(git checkout -b docs/*:*)",
      "Bash(git checkout -b hotfix/*:*)",
      "Bash(git checkout feature/*:*)",
      "Bash(git checkout main:*)",
      "Bash(git push -u origin feature/*:*)",
      "Bash(git push origin feature/*:*)",
      "Bash(git push -u origin fix/*:*)",
      "Bash(git push origin fix/*:*)",
      "Bash(git push -u origin docs/*:*)",
      "Bash(git push origin docs/*:*)",
      "Bash(git rebase:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --rebase:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh api /repos/*:*)",
      "Bash(bundle:*)",
      "Bash(bundle exec:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(jekyll:*)",
      "Bash(rspec:*)",
      "Bash(lychee:*)",
      "Bash(htmlproofer:*)",
      "Bash(scripts/*:*)",
      "Bash(./scripts/*:*)"
    ],
    "deny": [
      "Bash(git push origin main:*)",
      "Bash(git push origin main)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git reset --hard:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr merge)",
      "Bash(gh api -X PATCH /repos/*/branches/main/protection*)",
      "Bash(gh api -X PUT /repos/*/branches/main/protection*)",
      "Bash(gh api -X DELETE /repos/*/branches/main/protection*)",
      "Bash(gh api -X DELETE /repos/*:*)"
    ]
  }
}
